  "name": "酒馆菜单精简器",
  "id": "3f5dba4b-ffdf-4569-89f3-639c684f0288",
  "content": "import 'https://cdn.jsdelivr.net/gh/Harrishao/Fvck-the-useless-DOMs@v0/dist/menu-cleaner.js'",
  "info": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"utf-8\">\n<style>\nbody {\n  background-color: #0b0c10;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  height: 100vh;\n  margin: 0;\n  font-family: 'Microsoft YaHei', sans-serif;\n}\n.card {\n  position: relative;\n  padding: 40px 48px;\n  border-radius: 16px;\n  background: linear-gradient(135deg, rgba(30,30,50,0.9), rgba(15,15,30,0.95));\n  border: 1px solid rgba(255,255,255,0.08);\n  box-shadow: 0 0 40px rgba(127,0,255,0.15), 0 0 80px rgba(0,240,255,0.08), 0 20px 60px rgba(0,0,0,0.5);\n  text-align: center;\n}\n.card::before {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  border-radius: 16px;\n  padding: 1px;\n  background: linear-gradient(135deg, #ff007f, #7f00ff, #00f0ff, #7f00ff, #ff007f);\n  background-size: 400% 400%;\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n  -webkit-mask-composite: xor;\n  mask-composite: exclude;\n  animation: rotateBorder 6s linear infinite;\n}\n.card::after {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  border-radius: 16px;\n  background: radial-gradient(circle at 0% 0%, rgba(255,0,127,0.3) 0%, transparent 40%),\n              radial-gradient(circle at 100% 0%, rgba(0,240,255,0.3) 0%, transparent 40%),\n              radial-gradient(circle at 0% 100%, rgba(0,240,255,0.2) 0%, transparent 40%),\n              radial-gradient(circle at 100% 100%, rgba(127,0,255,0.3) 0%, transparent 40%);\n}\nh1 {\n  position: relative;\n  z-index: 1;\n  font-size: 36px;\n  font-weight: 900;\n  letter-spacing: 2px;\n  color: #e0e0f0;\n  text-shadow: 0 0 10px rgba(0,240,255,0.5), 0 0 30px rgba(127,0,255,0.3);\n  line-height: 1.5;\n}\n@keyframes rotateBorder {\n  0%   { background-position: 0% 0%; }\n  100% { background-position: 400% 0%; }\n}\n</style>\n</head>\n<body>\n<div class=\"card\">\n  <h1>再见了，那些玩一辈子酒馆都不会点的按钮</h1>\n</div>\n</body>\n</html>\n",
  "button": {
    "enabled": true,
    "buttons": []
  },
  "data": {}
}